# NOTE: This .env file contains sensitive data. NEVER commit this to version control.
# Copy .env.example to .env and fill in your actual values

# Anthropic Claude API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alexa Skill Configuration
ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application Settings
FLASK_ENV=development
FLASK_DEBUG=True
NGROK_URL=https://your-ngrok-url.ngrok.io

# Optional: Enable/Disable signature verification (False for local dev)
VERIFY_SIGNATURE=False
